<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <!-- Encabezado -->
    <FrameLayout
        android:id="@+id/contenedorEncabezado"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_header_gradient"
        android:clipToOutline="true"
        android:elevation="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="18dp"
            android:paddingEnd="22dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reporte Urbano"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#33FFFFFF"
                    android:paddingStart="11dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="11dp"
                    android:paddingBottom="6dp"
                    android:text="PASO 1 DE 2"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSubtitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Indica en el mapa dónde ocurrió la incidencia"
                android:textColor="#E0FFFB"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="MAPA INTERACTIVO   •   QUITO"
                android:textColor="#CCFBF1"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

    </FrameLayout>

    <!-- Tarjeta del mapa -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMapa"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="12dp"
        android:clipToOutline="true"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="#BFD5E2"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/cardDatosUbicacion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedorEncabezado">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <org.maplibre.android.maps.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Instrucción visual -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="16dp"
                android:background="#F8FAFC"
                android:elevation="3dp"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INSTRUCCIÓN"
                    android:textColor="#0F766E"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Toque el mapa para seleccionar la ubicación"
                    android:textColor="#16324F"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Tarjeta inferior -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDatosUbicacion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:strokeColor="#D8E4EA"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Encabezado de la ubicación -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#CCFBF1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#0F766E"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTituloUbicacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ubicación del incidente"
                        android:textColor="#102A43"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Selecciona el punto con precisión"
                        android:textColor="#718096"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#FFF4E5"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="REQUERIDO"
                    android:textColor="#B45309"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Coordenadas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#F0FDFA"
                app:cardCornerRadius="17dp"
                app:cardElevation="0dp"
                app:strokeColor="#99D9D2"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tvCoordenadas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="58dp"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp"
                    android:text="Toque el mapa para seleccionar un punto"
                    android:textColor="#35605D"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Botón ubicación actual -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUsarUbicacion"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="13dp"
                android:text="Usar mi ubicación actual"
                android:textAllCaps="false"
                android:textColor="#0F766E"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#E6FFFA"
                app:cornerRadius="17dp"
                app:strokeColor="#5EEAD4"
                app:strokeWidth="1dp" />

            <!-- Botón confirmar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmarUbicacion"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="9dp"
                android:enabled="false"
                android:text="Confirmar ubicación"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#0F766E"
                app:cornerRadius="17dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>