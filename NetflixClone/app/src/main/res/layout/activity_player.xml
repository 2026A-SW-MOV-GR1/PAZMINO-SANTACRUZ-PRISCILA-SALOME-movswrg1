<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/netflix_black"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:background="@color/netflix_black">

            <androidx.media3.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/netflix_black"
                app:show_buffering="when_playing"
                app:use_controller="true" />

            <ProgressBar
                android:id="@+id/playerLoading"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:indeterminateTint="@color/netflix_red" />

            <TextView
                android:id="@+id/btnClosePlayer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:background="#AA000000"
                android:gravity="center"
                android:text="×"
                android:textColor="@color/netflix_white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlayerLabel"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="22dp"
                android:layout_marginEnd="18dp"
                android:background="@color/netflix_red"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="REPRODUCIENDO"
                android:textColor="@color/netflix_white"
                android:textSize="11sp"
                android:textStyle="bold" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvPlayerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Título"
                android:textColor="@color/netflix_white"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlayerSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Género"
                android:textColor="@color/netflix_gray"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvPlayerDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Descripción"
                android:textColor="@color/netflix_white"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvPlayerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Preparando reproducción..."
                android:textColor="@color/netflix_red"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Nota: el video es una muestra local usada para simular la experiencia de streaming."
                android:textColor="@color/netflix_gray"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>